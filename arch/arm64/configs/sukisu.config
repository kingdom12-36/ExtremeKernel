# ExtremeKernel config for SukiSU
# SukiSU is a fork of KernelSU-Next; both support CONFIG_KSU_MANUAL_HOOK.
# Use manual-hook mode — kernel source already has ksu_handle_* call sites.
# Without this flag, SukiSU falls into kprobe-syscall-hook mode which fails
# to compile on Samsung Exynos 4.14 (ARM64 asm/syscall.h lacks syscall_fn_t).

CONFIG_KSU=y
# CONFIG_KSU_DEBUG is not set
CONFIG_KSU_ALLOWLIST_WORKAROUND=y

# Manual hooks (CRITICAL — do not remove for 4.14 ARM64 builds)
CONFIG_KSU_MANUAL_HOOK=y

# Exynos 9825 base defconfig already enables KPROBES; re-state here to
# satisfy SukiSU Kconfig's "depends on KPROBES && EXT4_FS" check explicitly.
CONFIG_KPROBES=y

#
# KernelSU - SUSFS
#
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_SUS_MAP=y
# end of KernelSU - SUSFS

# Memory / I/O tuning
CONFIG_VM_MAX_READAHEAD_KB=512
# EOF
