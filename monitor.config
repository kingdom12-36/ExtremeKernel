# ExtremeKernel — WiFi Monitor Mode Config Fragment
# Applied when building the KPatch+Monitor kernel variant (-n Y)
# Enables raw packet capture and 802.11 management frame visibility

# Wireless Extensions API (iwconfig compat, needed by some monitor tools)
CONFIG_CFG80211_WEXT=y

# NL80211 test mode (required for some driver monitor-mode commands)
CONFIG_NL80211_TESTMODE=y

# Raw packet socket support (required for tcpdump / tshark)
CONFIG_PACKET=y
CONFIG_PACKET_DIAG=y

# Monitor mode on mesh interfaces
CONFIG_MAC80211_MONITOR_MESH=y
